# Deny direct access to the SQLite database file
<FilesMatch "\.db$">
    Require all denied
</FilesMatch>

# Deny access to config file
<FilesMatch "^config\.php$">
    Require all denied
</FilesMatch>

# Deny access to db.php (internal include only)
<FilesMatch "^db\.php$">
    Require all denied
</FilesMatch>
